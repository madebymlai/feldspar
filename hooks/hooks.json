{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "id": "session:feldspar-start",
        "description": "Auto-start feldspar daemon and inject orchestrator context",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/hooks/scripts/session-start.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "id": "feldspar:record-change",
        "description": "Capture file changes for AR evaluation",
        "hooks": [
          {
            "type": "command",
            "command": "feldspar hook record-change",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
